{
  "name": "node-api-boilerplate",
  "version": "1.0.0",
  "description": "A simple and clean Node.js API boilerplate using Express.js.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/douglasalfaro/node-api-boilerplate.git"
  },
  "keywords": [
    "nodejs",
    "express",
    "api",
    "rest-api",
    "boilerplate",
    "starter"
  ],
  "author": "Douglas Alfaro",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/douglasalfaro/node-api-boilerplate/issues"
  },
  "homepage": "https://github.com/douglasalfaro/node-api-boilerplate#readme",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^5.1.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
